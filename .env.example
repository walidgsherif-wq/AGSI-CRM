# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (never expose in client bundle)
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Initial admin bootstrap (§16 D-7)
INITIAL_ADMIN_EMAIL=walid.g.sherif@gmail.com

# Email (deferred for v1 per §16 D-3 — leave blank)
RESEND_API_KEY=

# Dev-only role switcher (§M1). Only read when NODE_ENV !== 'production'.
# Valid: admin | leadership | bd_head | bd_manager
NEXT_PUBLIC_DEV_ROLE_DEFAULT=admin
